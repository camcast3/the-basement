# =============================================================================
# Omni On-Prem — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# When deploying as a Portainer stack, set these in the Portainer UI instead.
# =============================================================================

# --- Omni Version -----------------------------------------------------------
# Container image tag for Omni. Check releases at:
# https://github.com/siderolabs/omni/releases
OMNI_VERSION=v1.5.10

# --- Domain & Network -------------------------------------------------------
# Public domain name for Omni (must have DNS pointing to this host)
OMNI_DOMAIN=omni.local.example.com

# WireGuard IP — internal IP used for the WireGuard mesh that connects
# Omni to managed Talos nodes (e.g. the host's LAN IP)
OMNI_WIREGUARD_IP=10.10.1.100

# HTTP port Omni listens on for the web UI (Traefik proxies to this)
OMNI_HTTP_PORT=8080

# --- Data Directory ----------------------------------------------------------
# Path on the host where Omni stores data, certs, and GPG key.
# This directory must contain:
#   omni.asc                  — GPG encryption key for etcd
#   certs/fullchain.pem       — TLS certificate (for machine-facing ports)
#   certs/privkey.pem         — TLS private key
OMNI_DATA_DIR=/opt/omni

# --- Account -----------------------------------------------------------------
# Unique UUID for this Omni instance (generate with: uuidgen)
OMNI_ACCOUNT_UUID=CHANGE_ME

# Admin email — first user granted access to Omni
OMNI_ADMIN_EMAIL=admin@example.com

# --- Authentication (SAML with Authentik) ------------------------------------
# SAML metadata URL from Authentik.
# Format: https://<authentik-domain>/application/saml/<app-slug>/metadata/
SAML_METADATA_URL=https://authentik.local.example.com/application/saml/omni/metadata/

# --- Proxmox Provider (optional) --------------------------------------------
# Container image tag for the Proxmox infrastructure provider
PROXMOX_PROVIDER_VERSION=latest

# Service account key from Omni UI (Settings → Service Accounts).
# Role MUST be InfraProvider. Generate after Omni is running.
# Leave empty on first deploy, then update after creating the SA.
OMNI_SERVICE_ACCOUNT_KEY=CHANGE_ME_AFTER_FIRST_START
